# =============================================================================
# m365-gdap-inventory — .gitignore
# =============================================================================
# Anything secret, anything tenant-specific that came from a live API export,
# anything generated by a run, anything machine-local. The whole repo is
# already inside the Dropbox-excluded `exc_project/` tree, so this is
# belt-and-braces — but git is the cross-machine sync, and we want commits
# clean.

# -----------------------------------------------------------------------------
# Run artefacts (per-tenant workbooks, rollup, run-summary CSV)
# -----------------------------------------------------------------------------
# Anything written under output/ is the result of a run against real customer
# tenants — DO NOT COMMIT. Run-summary CSVs land here too.
output/
run-summary_*.csv

# -----------------------------------------------------------------------------
# AI / agent context (UOTech-internal; not for public consumption)
# -----------------------------------------------------------------------------
# CLAUDE.md is project context for AI assistants — internal workflow patterns
# and conventions that don't belong in a public-facing repo.
CLAUDE.md

# -----------------------------------------------------------------------------
# Local config (real values live outside the repo by convention)
# -----------------------------------------------------------------------------
# The schema example `tenants.config.json` is committed. Real configs that
# carry the partner-app clientId, tenant id, cert thumbprint, and per-tenant
# overrides are kept out via `.local.json` suffix or any per-host variant.
tenants.config.local.json
tenants.config.*.json
!tenants.config.json
!tenants.config.schema.json

# -----------------------------------------------------------------------------
# Cert material — NEVER commit
# -----------------------------------------------------------------------------
# Default PFX path is ~/.m365-multi-tenant-inventory/partner-app.pfx
# (outside the repo). These patterns are defensive in case anyone moves a
# cert under the repo by accident.
*.pfx
*.p12
*.cer
*.crt
*.pem
*.key
*.csr

# -----------------------------------------------------------------------------
# Partner Center exports
# -----------------------------------------------------------------------------
# Customer/GDAP CSVs are pulled fresh from Partner Center as needed; the live
# source is the portal export, not a stale copy in the repo.
Customers.csv
GranularAdministerRelationship.csv
*-customers.csv
*-gdap-relationships.csv

# -----------------------------------------------------------------------------
# Hudu / KB push artefacts
# -----------------------------------------------------------------------------
# If we ever materialize the rendered HTML locally before pushing, keep it out.
*.rendered.html
docs/*.html

# -----------------------------------------------------------------------------
# PowerShell artefacts
# -----------------------------------------------------------------------------
*.log
*.transcript
Transcripts/
.psmodulecache/
PesterResults*.xml
TestResults/

# -----------------------------------------------------------------------------
# Python helper artefacts (used for one-off CSV / JSON munging)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# -----------------------------------------------------------------------------
# Node helper artefacts (in case we add any JS/TS tooling later)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Editor / IDE noise
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.history/
*.code-workspace

# -----------------------------------------------------------------------------
# OS noise
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Backup / temp
# -----------------------------------------------------------------------------
*.bak
*.orig
*.tmp
*.tmp.*
tmp/
scratch/

# -----------------------------------------------------------------------------
# Just in case — generic secrets surface
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets.json
secrets/
